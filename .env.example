#Comma-separated SerpAPI keys
SERPAPI_KEYS=key1,key2,key3

#Discord webhooks per board
DISCORD_WEBHOOK_GREENHOUSE=
DISCORD_WEBHOOK_LEVER=
DISCORD_WEBHOOK_ASHBYHQ=
DISCORD_WEBHOOK_SMARTRECRUITERS=
DISCORD_WEBHOOK_WORKABLE=
DISCORD_WEBHOOK_RIPPLEMATCH=

#Monitoring SQLLite Databases(for new listing tracking)
GREENHOUSE_DB=greenhouse_watch.db
ASHBY_DB=ashbyhq_watch.db
LEVER_DB=lever_watch.db
SMARTRECRUITERS_DB=smartrecruiters_watch.db
WORKABLE_DB=workable_watch.db
RIPPLEMATCH_DB=ripplematch_watch.db
STATUS_DB=monitor_status.db

#Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

#Interval timing
POLL_INTERVAL_SECONDS=30
CONCURRENCY=6
JITTER_SECONDS=10
TIMEOUT_SECONDS=5
ASHBY_MAX_RETRIES=8
ASHBY_BASE_BACKOFF_SECONDS=2.0
ASHBY_REQUEST_SPACING_SECONDS=3.0
