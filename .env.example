# Comma-separated SerpAPI keys for company discovery
SERPAPI_KEYS=key1,key2,key3

# Discord webhooks per board
DISCORD_WEBHOOK_GREENHOUSE=
DISCORD_WEBHOOK_LEVER=
DISCORD_WEBHOOK_ASHBYHQ=

# Optional shared Slack webhook
SLACK_WEBHOOK_URL=

# Monitoring SQLite databases for new listing tracking
GREENHOUSE_DB=greenhouse_watch.db
ASHBY_DB=ashbyhq_watch.db
LEVER_DB=lever_watch.db
STATUS_DB=monitor_status.db
JOB_DB=job_intelligence.db

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=18080

# Metrics / Grafana
METRICS_HOST=0.0.0.0
METRICS_PORT=19108
PROMETHEUS_PORT=19090
GRAFANA_PORT=13000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Logging
LOG_LEVEL=INFO

# Monitor supervisor
MONITOR_RESTART_BASE_SECONDS=5
MONITOR_RESTART_MAX_SECONDS=120

# Local job classification
LOCAL_CLASSIFICATION_ENABLED=true
LOCAL_CLASSIFIER_MODEL=local-keyword-v1
LOCAL_CLASSIFIER_MAX_DESCRIPTION_CHARS=1500
MIN_RELEVANCE_SCORE=75
JOB_LAST_SEEN_UPDATE_INTERVAL_SECONDS=21600

# Polling and request timing
POLL_INTERVAL_SECONDS=30
JITTER_SECONDS=10
TIMEOUT_SECONDS=5

# Monitor limits
COMPANY_LIMIT=0
CONCURRENCY=6
COMPANIES_PER_SECOND=2.0

# Ashby rate limits are tighter than Greenhouse/Lever. These override the global
# settings for ashby.py only.
ASHBY_POLL_INTERVAL_SECONDS=300
ASHBY_JITTER_SECONDS=60
ASHBY_CONCURRENCY=2
ASHBY_COMPANIES_PER_SECOND=0.35
ASHBY_MAX_RETRIES=6
ASHBY_BACKOFF_BASE_SECONDS=5.0
ASHBY_BACKOFF_MAX_SECONDS=180.0
ASHBY_GLOBAL_429_COOLDOWN_SECONDS=60.0

# Retry/backoff
MAX_RETRIES=5
BACKOFF_BASE_SECONDS=1.0
BACKOFF_MAX_SECONDS=30.0
GLOBAL_429_COOLDOWN_SECONDS=0.0
